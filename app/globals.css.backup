@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --font-geist-sans: 'Geist', sans-serif;
  --font-geist-mono: 'Geist Mono', monospace;
  --background: 0 0% 100%;
  --foreground: 0 0% 10%;
}

html.dark {
  --background: 0 0% 5%;
  --foreground: 0 0% 95%;
}

body {
  background-color: hsl(var(--background));
  color: hsl(var(--foreground));
  font-family: var(--font-geist-sans), sans-serif;
}

/* 모달이 활성화되었을 때 body 스크롤 방지 */
body.modal-open {
  overflow: hidden;
  height: 100vh;
  position: fixed;
  width: 100%;
  top: 0;
  left: 0;
}

/* 모든 기본 요소들의 z-index를 확실히 낮게 설정 */
header, main, nav, aside {
  z-index: 1 !important;
  position: relative;
}

/* 모달 스타일 강화 - 더 높은 z-index 사용 */
.modal-backdrop {
  z-index: 999999 !important;
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background-color: rgba(0, 0, 0, 0.5) !important;
  inset: 0 !important;
}

/* Tailwind와의 충돌 방지 */
.modal-backdrop {
  @apply fixed inset-0 bg-black bg-opacity-50;
}
